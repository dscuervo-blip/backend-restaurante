{
    "name": "ms-pedidos/api",
    "description": "Microservicio de Pedidos con Slim Framework 4 y Eloquent ORM",
    "type": "project",
    "require": {
        "php": "^8.0",
        "slim/slim": "^4.11",
        "slim/psr7": "^1.6",
        "illuminate/database": "^10.0",
        "vlucas/phpdotenv": "^5.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
